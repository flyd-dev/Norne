# =============================================================================
# Norne Chatbot — environment variables
# Copy this file to `.env.local` and fill in real values there.
# `.env.local` is git-ignored. NEVER commit real secrets.
# =============================================================================

# --- LLM provider ------------------------------------------------------------
# Which LLM backend to use: "anthropic" (default, Claude), "openai", or
# "ollama" (local Llama).
LLM_PROVIDER=anthropic

# --- Anthropic / Claude (used when LLM_PROVIDER=anthropic) --------------------
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=

# --- OpenAI (used when LLM_PROVIDER=openai) -----------------------------------
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=

# --- Ollama / local or remote Llama (used when LLM_PROVIDER=ollama) -----------
# Point at a running Ollama server and a pulled model.
#   Local:  http://localhost:11434
#   Remote: https://your-ollama-domain.example.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Optional. Only needed when the endpoint is behind bearer auth (e.g. a reverse
# proxy on a remote VPS). Sent as `Authorization: Bearer <key>`. Leave blank for
# local Ollama, which usually has no auth.
OLLAMA_API_KEY=

# --- Admin: document upload --------------------------------------------------
# Token required to access /admin/documents and upload company documents.
# If unset, the document-upload admin routes are disabled. Server-side only.
ADMIN_UPLOAD_TOKEN=

# Where uploaded-document metadata + chunks are stored (local JSON file, NOT
# Firestore). Optional; defaults to /var/lib/norne-chatbot/knowledge-documents.json
DOCUMENT_STORE_PATH=

# Where answer feedback (👍/👎 + corrections) is stored (local JSON file). Holds
# no secrets, no full chat history and no document contents. Optional; defaults
# to /var/lib/norne-chatbot/feedback.json. View/export at /admin/documents.
DOCUMENT_FEEDBACK_PATH=

# --- Endre API (OPTIONAL — external project/economy data) --------------------
# Optional integration with Endre's public REST API (https://public-api.endre.app).
# DISABLED by default. The chatbot works without it: leave ENDRE_API_ENABLED=false
# and the existing Firebase/document flow is untouched. The integration is only
# used when ENDRE_API_ENABLED=true AND a username + password are present.
# Never commit real credentials — fill these in `.env.local` only.
ENDRE_API_ENABLED=false
ENDRE_API_BASE_URL=https://public-api.endre.app
ENDRE_API_USERNAME=
ENDRE_API_PASSWORD=
# Optional. Only set if Endre issues a client_id/client_secret for the OAuth2
# password grant. Leave blank otherwise.
ENDRE_API_CLIENT_ID=
ENDRE_API_CLIENT_SECRET=

# --- Firebase project --------------------------------------------------------
FIREBASE_PROJECT_ID=

# =============================================================================
# Firestore access — choose ONE of the two backends below.
# The app auto-detects which one to use based on the variables you set.
# =============================================================================

# --- Option A (PREFERRED): Firebase Admin SDK (service account) --------------
# Requires a service-account JSON from:
#   Firebase Console > Project settings > Service accounts > Generate new private key
# Paste the values from that JSON. The private key must keep its \n line breaks
# (wrap the whole value in double quotes as shown).
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Option B (fallback): Firestore REST API (email/password sign-in) --------
# Use this if you do NOT have a service-account key, only a web API key plus a
# Firebase Auth email/password user. This is the flow described in
# api-service-account.md. The app uses Option B only when Option A is not set.
FIREBASE_API_KEY=
FIREBASE_AUTH_EMAIL=
FIREBASE_AUTH_PASSWORD=
