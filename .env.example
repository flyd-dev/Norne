# =============================================================================
# Norne Chatbot — environment variables
# Copy this file to `.env.local` and fill in real values there.
# `.env.local` is git-ignored. NEVER commit real secrets.
# =============================================================================

# --- Site password lock (REQUIRED in production) -----------------------------
# A single shared password gates the whole site (see middleware.ts). There is NO
# built-in default in production: if PASSWORD/SECRET are unset on a production
# deploy the site fails closed (nobody can log in) rather than shipping a known
# password. In local dev an obvious placeholder is used so `next dev` just works.
# Rotating SITE_AUTH_SECRET invalidates every existing login (cookie signing salt).
SITE_AUTH_USER=Admin
SITE_AUTH_PASSWORD=
SITE_AUTH_SECRET=

# --- LLM provider ------------------------------------------------------------
# Which LLM backend to use: "anthropic" (default, Claude), "openai", or
# "ollama" (local Llama).
LLM_PROVIDER=anthropic

# --- Anthropic / Claude (used when LLM_PROVIDER=anthropic) --------------------
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=

# --- OpenAI (used when LLM_PROVIDER=openai) -----------------------------------
OPENAI_API_KEY=
# Optional. Defaults to gpt-4o-mini if unset.
OPENAI_MODEL=

# --- Ollama / local or remote Llama (used when LLM_PROVIDER=ollama) -----------
# Point at a running Ollama server and a pulled model.
#   Local:  http://localhost:11434
#   Remote: https://your-ollama-domain.example.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Optional. Only needed when the endpoint is behind bearer auth (e.g. a reverse
# proxy on a remote VPS). Sent as `Authorization: Bearer <key>`. Leave blank for
# local Ollama, which usually has no auth.
OLLAMA_API_KEY=

# --- Admin: document upload --------------------------------------------------
# Token required to access /admin/documents and upload company documents.
# If unset, the document-upload admin routes are disabled. Server-side only.
ADMIN_UPLOAD_TOKEN=

# --- Storage backend (VPS vs serverless/Vercel) ------------------------------
# Where the app's OWN data (document chunks + vectors, dossier, feedback, sync
# cursors) is persisted. Domain data (accounts/projects) is ALWAYS read from
# Firestore and is unaffected by this setting.
#   "local" (default) — JSON/SQLite files on a writable disk (VPS). Uses the
#                        *_PATH and VECTOR_STORE_PATH vars below.
#   "cloud"           — everything the app writes goes to Turso (libSQL).
#                        REQUIRED on Vercel (no persistent filesystem). Needs the
#                        TURSO_* vars below. NO Firebase service account needed —
#                        Firebase keeps its existing read-only setup.
STORE_BACKEND=local

# Vector backend. "sqlite" (default) = local better-sqlite3 + sqlite-vec file.
# "turso" = managed libSQL over HTTP (serverless). better-sqlite3 is never
# imported when this is "turso". Set to "turso" when STORE_BACKEND=cloud.
VECTOR_BACKEND=sqlite
# Turso (libSQL) connection — used by the cloud backend (VECTOR_BACKEND=turso
# and/or STORE_BACKEND=cloud). Create a database at https://turso.tech (free
# tier) and read these from the dashboard / CLI.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Secret for the Vercel Cron route (/api/cron/sync, nightly sync + dossier).
# Set this on Vercel and it sends it automatically as a Bearer token. Unset =
# cron route disabled. Not used on the VPS (cron there runs nightly-update.sh).
CRON_SECRET=

# Where uploaded-document metadata + chunks are stored (local JSON file, NOT
# Firestore). Optional; defaults to /var/lib/norne-chatbot/knowledge-documents.json
DOCUMENT_STORE_PATH=

# Where answer feedback (👍/👎 + corrections) is stored (local JSON file). Holds
# no secrets, no full chat history and no document contents. Optional; defaults
# to /var/lib/norne-chatbot/feedback.json. View/export at /admin/documents.
DOCUMENT_FEEDBACK_PATH=

# --- Semantic document search (RAG / vector search) --------------------------
# Embeddings power semantic search over uploaded/synced documents (scales far
# past the JSON keyword index — needed for large corpora like a SharePoint sync).
# NOTE: Anthropic/Claude has no embeddings API — embeddings are a separate model
# type, so this needs its own provider (Claude still generates the answers).
#
# EMBEDDINGS_PROVIDER:
#   "voyage" — Anthropic's recommended provider; hosted, generous free tier,
#              nothing to install. Needs VOYAGE_API_KEY below. RECOMMENDED.
#   "ollama" — free + local; run Ollama on the server and
#              `ollama pull nomic-embed-text` (uses OLLAMA_BASE_URL above).
#   "openai" — cheap hosted; reuses OPENAI_API_KEY above.
#   "none"   — disable semantic search; keyword index only.
EMBEDDINGS_PROVIDER=voyage
# Voyage API key (get one at https://www.voyageai.com). Required when
# EMBEDDINGS_PROVIDER=voyage. Server-side only.
VOYAGE_API_KEY=
# Embedding model. Optional; defaults to voyage-3.5 (Voyage) / nomic-embed-text
# (Ollama) / text-embedding-3-small (OpenAI). Changing this requires deleting
# VECTOR_STORE_PATH and re-indexing (the vector dimension is fixed at first build).
EMBEDDINGS_MODEL=
# Where chunk embeddings are stored (local sqlite-vec file, NOT Firestore).
# Optional; defaults to /var/lib/norne-chatbot/vectors.db
VECTOR_STORE_PATH=

# Case dossier: a generated whole-case overview, synthesised across all indexed
# documents and injected on case/overview questions. Built on demand with
# scripts/generate-dossier.mjs (one LLM call). Local JSON file, NOT Firestore.
# Optional; defaults to /var/lib/norne-chatbot/case-dossier.json
DOSSIER_PATH=

# --- Endre API (OPTIONAL — external project/economy data) --------------------
# Optional integration with Endre's public REST API (https://public-api.endre.app).
# DISABLED by default. The chatbot works without it: leave ENDRE_API_ENABLED=false
# and the existing Firebase/document flow is untouched. The integration is only
# used when ENDRE_API_ENABLED=true AND a username + password are present.
# Never commit real credentials — fill these in `.env.local` only.
ENDRE_API_ENABLED=false
ENDRE_API_BASE_URL=https://public-api.endre.app
ENDRE_API_USERNAME=
ENDRE_API_PASSWORD=
# Optional. Only set if Endre issues a client_id/client_secret for the OAuth2
# password grant. Leave blank otherwise.
ENDRE_API_CLIENT_ID=
ENDRE_API_CLIENT_SECRET=

# --- SharePoint sync (OPTIONAL — Microsoft Graph) ----------------------------
# Sync a SharePoint document library into the knowledge base via Microsoft Graph
# (app-only / client credentials). DISABLED by default. NO paid Azure needed —
# the app registration lives in Entra ID, which is included with the Microsoft
# 365 tenant that already hosts SharePoint.
#
# Setup (a tenant admin does this once):
#   1) Entra ID → App registrations → New registration.
#   2) API permissions → Microsoft Graph → Application → Sites.Read.All
#      (+ Files.Read.All) → "Grant admin consent".
#   3) Certificates & secrets → New client secret.
# Then trigger sync with:  node scripts/sync-sharepoint.mjs
SHAREPOINT_ENABLED=false
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# The site to sync as "{hostname}:/sites/{path}", e.g.
# flyd.sharepoint.com:/sites/Dokumenter
SHAREPOINT_SITE=
# Optional: restrict to specific document libraries (comma-separated names).
# Empty = every library on the site.
SHAREPOINT_DRIVES=
# Optional: restrict to ONE folder (and its descendants), as a path relative to
# the library root, e.g. General/Kunde/Nornebygg. Empty = whole library. Use this
# to avoid indexing unrelated folders (e.g. other clients) into the shared base.
SHAREPOINT_FOLDER=
# Optional: skip files larger than this many MB (default 25).
SHAREPOINT_MAX_FILE_MB=25
# Optional: where per-drive delta cursors are stored (local JSON). Defaults to
# /var/lib/norne-chatbot/sharepoint-sync.json
SHAREPOINT_STATE_PATH=

# --- Firebase project --------------------------------------------------------
FIREBASE_PROJECT_ID=

# =============================================================================
# Firestore access — choose ONE of the two backends below.
# The app auto-detects which one to use based on the variables you set.
# =============================================================================

# --- Option A (PREFERRED): Firebase Admin SDK (service account) --------------
# Requires a service-account JSON from:
#   Firebase Console > Project settings > Service accounts > Generate new private key
# Paste the values from that JSON. The private key must keep its \n line breaks
# (wrap the whole value in double quotes as shown).
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- Option B (fallback): Firestore REST API (email/password sign-in) --------
# Use this if you do NOT have a service-account key, only a web API key plus a
# Firebase Auth email/password user. This is the flow described in
# api-service-account.md. The app uses Option B only when Option A is not set.
FIREBASE_API_KEY=
FIREBASE_AUTH_EMAIL=
FIREBASE_AUTH_PASSWORD=
