# =============================================================================
# Norne Chatbot — VPS / production example (Ollama on the SAME server)
#
# Copy to `.env.local` (or `.env.production`) ON THE VPS and fill in Firebase.
# These target files are git-ignored — NEVER commit real secrets.
# =============================================================================

# --- LLM provider: local Ollama on this VPS ----------------------------------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Optional. Leave blank: local Ollama on localhost needs no auth.
OLLAMA_API_KEY=

# No OPENAI_API_KEY is required when LLM_PROVIDER=ollama.

# --- Admin: document upload --------------------------------------------------
# Token required to upload documents at /admin/documents. Use a long random
# value. Server-side only; never commit the real value.
ADMIN_UPLOAD_TOKEN=

# Uploaded documents are stored in this local JSON file on the VPS (NOT in
# Firestore). The directory is created automatically; ensure the app process
# can write to it. Defaults to /var/lib/norne-chatbot/knowledge-documents.json
DOCUMENT_STORE_PATH=/var/lib/norne-chatbot/knowledge-documents.json

# Answer feedback (👍/👎 + corrections) is appended to this local JSON file on the
# VPS. No secrets, no full chat history, no document contents are stored. The app
# process must be able to write to it. View/export it from /admin/documents.
DOCUMENT_FEEDBACK_PATH=/var/lib/norne-chatbot/feedback.json

# --- Endre API (OPTIONAL) ----------------------------------------------------
# Optional external integration, DISABLED by default. Safe to leave as-is: the
# app runs fully without it. Set ENDRE_API_ENABLED=true and fill in the username
# + password only once the integration has been confirmed for this deployment.
ENDRE_API_ENABLED=false
ENDRE_API_BASE_URL=https://public-api.endre.app
ENDRE_API_USERNAME=
ENDRE_API_PASSWORD=
# ENDRE_API_CLIENT_ID=
# ENDRE_API_CLIENT_SECRET=

# --- Firebase project --------------------------------------------------------
FIREBASE_PROJECT_ID=

# Provide ONE Firestore backend.
# Option A (preferred) — Admin SDK service account:
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Option B (fallback) — REST sign-in (web API key + email/password user):
# FIREBASE_API_KEY=
# FIREBASE_AUTH_EMAIL=
# FIREBASE_AUTH_PASSWORD=
